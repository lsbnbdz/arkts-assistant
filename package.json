{
  "name": "arkts-assistant-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for ArkTS development assistant with custom documentation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "arkts-assistant": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http",
    "generate-index": "tsx scripts/generate-index.ts"
  },
  "keywords": [
    "mcp",
    "arkts",
    "harmonyos",
    "documentation",
    "assistant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2",
    "segmentit": "^2.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
